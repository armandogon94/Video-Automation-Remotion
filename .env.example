# AI Video Factory — Environment Variables
# Copy this to .env and fill in values

# Optional: ElevenLabs API key (only if using premium TTS)
# ELEVENLABS_API_KEY=your_key_here

# Optional: Anthropic API key (for subtitle translation via Claude)
# ANTHROPIC_API_KEY=your_key_here

# Optional: DeepL API key (alternative translation)
# DEEPL_API_KEY=your_key_here

# Remotion rendering settings
REMOTION_CONCURRENCY=2
REMOTION_QUALITY=80

# FFmpeg settings
FFMPEG_THREADS=4

# Default voice for TTS
DEFAULT_VOICE=es-MX-JorgeNeural
DEFAULT_LANGUAGE=es

# Output directory (relative to project root)
OUTPUT_DIR=./output
