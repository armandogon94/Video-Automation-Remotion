{
  "id": "listicle",
  "name": "Listicle with Transitions",
  "description": "Numbered list items with animated transitions (Armando Inteligencia branded)",
  "composition": "Listicle",
  "defaults": {
    "fps": 30,
    "width": 1920,
    "height": 1080,
    "durationBehavior": "fixed",
    "durationPerItem": 5,
    "transitionDuration": 0.5,
    "transitionType": "slide",
    "items": {
      "numberStyle": "circle",
      "numberColor": "#D4AF37",
      "textColor": "#FFFFFF",
      "fontSize": 44,
      "animation": "slideUp"
    },
    "background": {
      "type": "gradient",
      "from": "#1B3A6E",
      "to": "#0F1B2D"
    },
    "captions": {
      "enabled": true,
      "style": "highlighted",
      "fontSize": 28,
      "position": "bottom",
      "highlightColor": "#D4AF37"
    },
    "branding": {
      "logo": "avatar",
      "watermark": true,
      "introSlide": false,
      "outroSlide": false
    }
  },
  "platforms": {
    "youtube": { "width": 1920, "height": 1080 },
    "tiktok": { "width": 1080, "height": 1920 },
    "reels": { "width": 1080, "height": 1920 },
    "square": { "width": 1080, "height": 1080 }
  }
}
