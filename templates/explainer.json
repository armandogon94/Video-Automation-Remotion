{
  "id": "explainer",
  "name": "Text-on-Screen Explainer",
  "description": "Clean text explainer with brand gradient background and animated word-by-word captions",
  "composition": "ExplainerVideo",
  "defaults": {
    "fps": 30,
    "width": 1920,
    "height": 1080,
    "durationBehavior": "matchAudio",
    "background": {
      "type": "gradient",
      "from": "#1B3A6E",
      "to": "#0F1B2D"
    },
    "text": {
      "fontFamily": "Inter",
      "fontSize": 48,
      "color": "#FFFFFF",
      "position": "center"
    },
    "captions": {
      "enabled": true,
      "style": "highlighted",
      "fontSize": 36,
      "position": "bottom",
      "highlightColor": "#D4AF37",
      "backgroundColor": "rgba(15,27,45,0.75)"
    },
    "branding": {
      "logo": "avatar",
      "watermark": true,
      "introSlide": false,
      "outroSlide": false
    }
  },
  "platforms": {
    "youtube": { "width": 1920, "height": 1080 },
    "tiktok": { "width": 1080, "height": 1920 },
    "reels": { "width": 1080, "height": 1920 },
    "square": { "width": 1080, "height": 1080 }
  }
}
